# AI Content Automation - Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git (it's in .gitignore)

# ===== CMS Integration (Optimizely CMP) =====
# Get these from: Optimizely CMP > Settings > OAuth Applications
# If you use a different CMS, replace these with your CMS credentials
OPTIMIZELY_CLIENT_ID=your_client_id_here
OPTIMIZELY_CLIENT_SECRET=your_client_secret_here
OPTIMIZELY_OAUTH_TOKEN_URL=https://accounts.cmp.optimizely.com/o/oauth2/v1/token
OPTIMIZELY_SCOPE=content:write content:read

# Optimizely API Configuration
OPTIMIZELY_CMP_PROJECT_ID=
OPTIMIZELY_CMP_API_URL=https://api.cmp.optimizely.com/v3

# Campaign & Workflow IDs (find via Optimizely API or admin panel)
OPTIMIZELY_CAMPAIGN_ID=your_campaign_id_here
OPTIMIZELY_WORKFLOW_ID=your_workflow_id_here

# Content Type Configuration
OPTIMIZELY_BLOG_CONTENT_TYPE_GUID=your_content_type_guid_here
OPTIMIZELY_CONTENT_TYPE_GROUP_ID=your_content_type_group_id_here
OPTIMIZELY_BLOG_POST_LABEL_ID=your_blog_post_label_id_here

# Default Values
OPTIMIZELY_DEFAULT_CAMPAIGN=Your Campaign Name
OPTIMIZELY_DEFAULT_WORKFLOW=Your Workflow Name

# User Configuration
OPTIMIZELY_USER_EMAIL=your_email@company.com

# ===== WordPress Integration =====
# Get application password from: WordPress Admin > Users > Profile > Application Passwords
WORDPRESS_SITE_URL=https://your-wordpress-site.com
WORDPRESS_USERNAME=your_username
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx

# WordPress Settings
WORDPRESS_BLOG_CATEGORY_ID=1
WORDPRESS_DEFAULT_AUTHOR_ID=1
WORDPRESS_DEFAULT_STATUS=draft
WORDPRESS_AUTO_PUBLISH=false

# ===== Slack Integration =====
# Get bot token from: https://api.slack.com/apps > Your App > OAuth & Permissions
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_WORKSPACE_ID=your_workspace_id

# Slack Channels (get channel IDs from Slack channel settings)
SLACK_CONTENT_IDEAS_CHANNEL=C0EXAMPLE01
SLACK_RESEARCH_CHANNEL=C0EXAMPLE02
SLACK_NOTIFICATIONS_CHANNEL=C0EXAMPLE03

# Optional: Your Slack user ID (for mentions)
SLACK_YOUR_USER_ID=U0EXAMPLE01

# ===== Canva Integration =====
# Create a Canva app at: https://www.canva.com/developers/apps
CANVA_CLIENT_ID=your_client_id_here
CANVA_CLIENT_SECRET=your_client_secret_here
CANVA_API_URL=https://api.canva.com/rest/v1
CANVA_BRAND_TEMPLATE_ID=your_brand_template_id
CANVA_AUTO_PUBLISH=false

# Note: Access tokens are stored in .canva-tokens.json (auto-generated, do not commit)

# ===== Social Media Scheduler (Sprout Social) =====
# If you use a different scheduler (Buffer, Hootsuite, etc.), replace with your credentials
SPROUT_API_BASE_URL=https://api.advocacy.sproutsocial.com
SPROUT_CLIENT_ID=your_client_id_here
SPROUT_CLIENT_SECRET=your_client_secret_here
SPROUT_ACCESS_TOKEN=your_access_token_here
SPROUT_ADVOCACY_NETWORK_ID=your_network_id_here

# Sprout Settings (optional)
SPROUT_DEFAULT_MESSAGE_TEMPLATE=New from our team: {title} {url}
SPROUT_AUTO_TAGS=true
SPROUT_DEFAULT_TAGS=blog,content

# Testing Mode
# SPROUT_SKIP_IN_TESTING=true
# SPROUT_CREATE_AS_DRAFT=true

# ===== Content Lifecycle Notifications =====
CONTENT_LIFECYCLE_SLACK_CHANNEL=C0EXAMPLE04

# ===== Claude Code Configuration =====
CLAUDE_CODE_MAX_OUTPUT_TOKENS=16384

# ===== NOTES =====
# To find your IDs:
# 1. Optimizely: Check admin panel or use API endpoints
# 2. WordPress: Admin > Settings or inspect page source
# 3. Slack: Right-click channel name > Copy channel ID
# 4. Canva: Developer portal > Your apps
# 5. Sprout: Admin settings > API access
#
# See docs/setup-guide.md for complete setup instructions
